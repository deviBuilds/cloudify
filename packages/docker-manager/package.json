{
  "name": "@cloudify/docker-manager",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dockerode": "^4.0.0",
    "js-yaml": "^4.1.0",
    "@cloudify/shared": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "@types/dockerode": "^3.3.0",
    "@types/js-yaml": "^4.0.0"
  }
}
