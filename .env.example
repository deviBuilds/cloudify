# === Cloudflare DNS ===
# Zone:DNS:Edit + Zone:Zone:Read scoped token
CLOUDFLARE_API_TOKEN=
# Zone ID from Cloudflare dashboard
CLOUDFLARE_ZONE_ID=
# Account ID from Cloudflare dashboard
CLOUDFLARE_ACCOUNT_ID=

# === Nginx Proxy Manager ===
# NPM web UI URL (e.g., http://localhost:81)
NPM_URL=
# NPM admin email
NPM_EMAIL=
# NPM admin password
NPM_PASSWORD=

# === Server ===
# Public IP of the host running deployments
SERVER_IP=
# Base domain for subdomain routing
BASE_DOMAIN=devhomelab.org

# === Cloudify's Convex Instance ===
# Postgres password for Cloudify's own Convex backend
CLOUDIFY_DB_PASSWORD=
# Convex backend URL (e.g., http://localhost:3211)
CLOUDIFY_CONVEX_URL=
# Convex site origin
CLOUDIFY_CONVEX_SITE=
# Convex deploy key (for CI/CD schema push)
CONVEX_DEPLOY_KEY=

# === App ===
# Public Convex URL for Next.js client
NEXT_PUBLIC_CONVEX_URL=
# Shared secret between Convex actions and infra agent
INFRA_AGENT_SECRET=
# Infra agent URL (default: http://localhost:4000)
INFRA_AGENT_URL=http://localhost:4000
